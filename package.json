{
  "name": "jyotir",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @jyotir/web dev",
    "dev:mobile": "pnpm --filter @jyotir/mobile start",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "seed:generate": "tsx scripts/generate-seed.ts"
  },
  "devDependencies": {
    "@jyotir/content": "workspace:*",
    "@jyotir/core": "workspace:*",
    "tsx": "^4.19.2",
    "turbo": "^2.9.18",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"],
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7"
    }
  }
}
