{
  "expo": {
    "name": "Recall",
    "slug": "jyotir",
    "version": "0.1.0",
    "scheme": "recall",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.jyotir"
    },
    "android": {
      "package": "app.jyotir",
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router", "expo-sqlite"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
