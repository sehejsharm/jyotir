# Supabase (optional — the app runs fully offline without these)
NEXT_PUBLIC_SUPABASE_URL=
# Use your project's anon key OR the new publishable key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # alternative name, also accepted
# Public site URL (used for metadata + magic-link redirect), e.g. https://jyotir.vercel.app
NEXT_PUBLIC_SITE_URL=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (Prisma / seeding)
DATABASE_URL=
DIRECT_URL=
